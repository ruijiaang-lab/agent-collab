# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Claude Code runner ──────────────────────────────────────────────────────
# Leave AGENT_COLLAB_CLAUDE_BASE_URL blank to use the official Anthropic API.
# Set it to a third-party Anthropic-compatible endpoint (e.g. ThinkAI, OpenRouter).
AGENT_COLLAB_CLAUDE_BASE_URL=

# API key for the above endpoint. Leave blank if you rely on `claude login`.
AGENT_COLLAB_CLAUDE_API_KEY=

# Model name passed to --model. Default: claude-sonnet-4-6
AGENT_COLLAB_CLAUDE_MODEL=claude-sonnet-4-6

# Path to the claude binary if it's not on $PATH
# AGENT_COLLAB_CLAUDE_BIN=claude

# ── Hermes runner ───────────────────────────────────────────────────────────
# Leave AGENT_COLLAB_HERMES_BASE_URL blank to use the official Anthropic API.
AGENT_COLLAB_HERMES_BASE_URL=

# API key for the above endpoint. Leave blank if you rely on `hermes login`.
AGENT_COLLAB_HERMES_API_KEY=

# Path to the hermes binary if it's not on $PATH
# AGENT_COLLAB_HERMES_BIN=hermes

# ── Codex runner ────────────────────────────────────────────────────────────
# Path to the codex binary if it's not on $PATH
# AGENT_COLLAB_CODEX_BIN=codex

# ── Server ──────────────────────────────────────────────────────────────────
# PORT=5057
